{
  "builds": [
    {
      "src": "composer.json",
      "use": "@vercel/php"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "public/build"
      }
    }
  ],
  "routes": [
    {
      "src": "/((?!public/).*)",
      "dest": "index.php"
    }
  ]
}